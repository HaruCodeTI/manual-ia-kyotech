next-env.d.ts
.vercel

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Archives ----------
*.zip
*.tar.gz
*.rar

