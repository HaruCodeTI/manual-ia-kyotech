*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
env/
*.whl
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# ---------- Node / Frontend ----------
node_modules/
.next/
out/
.pnp
.pnp.*
.yarn/*
